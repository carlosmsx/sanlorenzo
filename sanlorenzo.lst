0080+  67C9             ; --- Posiciones iniciales de las 20 estrellas ---
0081+  67C9             ; Estructura: Y, X, DX, DY, edad
0082+  67C9             ; Posición inicial pre-calculada: Y = Yc+DY*edad, X = Xc+DX*edad
0083+  67C9             ; DX/DY: +1=1, +2=2, -1=255(0FFh), -2=254(0FEh)
