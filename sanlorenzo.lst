0151+  686D 11 50 80    	LD   DE, STAR_TABLE      ; destino: RAM
0152+  6870 01 64 00    	LD   BC, NUM_STARS * STAR_SIZE  ; 100 bytes
0153+  6873 ED B0       	LDIR                     ; copia directa ROM → RAM
0154+  6875             	; Seedear PRNG con el registro R del Z80.
0155+  6875             	; R se incrementa en cada lectura de memoria (varía con el timing de boot),
0156+  6875             	; así el efecto es distinto en cada ejecución.
0157+  6875 ED 5F       	LD   A, R
0158+  6877 B7          	OR   A
0159+  6878 20 01       	JR   NZ, IS_SEED_OK
0160+  687A 3C          	INC  A                   ; evitar semilla 0
0161+  687B             IS_SEED_OK:
0162+  687B 32 05 81    	LD   (RAND_SEED), A
0163+  687E AF          	XOR  A
0164+  687F 32 08 81    	LD   (STAR_DELAY), A     ; velocidad inicial: máxima (0=cada tick)
0165+  6882 32 09 81    	LD   (STAR_TICK), A
0166+  6885 C9          	RET
0167+  6886             
0168+  6886             ; --- TICK_STARS: gestiona el contador de velocidad y llama UPDATE_STARS ---
0169+  6886             ; Llamar desde EJEC en cada tick. Reemplaza la llamada directa a UPDATE_STARS.
0170+  6886             TICK_STARS:
0171+  6886 3A 07 81    	LD   A,(STARS_ON)
0172+  6889 B7          	OR   A
0173+  688A C8          	RET  Z                   ; estrellas apagadas
0174+  688B 3A 09 81    	LD   A,(STAR_TICK)
0175+  688E B7          	OR   A
0176+  688F 28 05       	JR   Z,TS_UPDATE
0177+  6891 3D          	DEC  A
0178+  6892 32 09 81    	LD   (STAR_TICK),A
0179+  6895 C9          	RET
0180+  6896             TS_UPDATE:
0181+  6896 3A 08 81    	LD   A,(STAR_DELAY)
