0107+  682D             ; --- Tabla de direcciones (16 pares DX,DY distribuidos en 360°) ---
0108+  682D             ; Se elige uno al azar (4 bits → índice 0..15) al reiniciar cada estrella.
0109+  682D             DIR_TABLE:
0110+  682D 02 00       	.DB   2,   0   ;  0  derecha
0111+  682F 02 01       	.DB   2,   1   ;  1  derecha-abajo suave
0112+  6831 02 02       	.DB   2,   2   ;  2  diagonal DR
0113+  6833 01 02       	.DB   1,   2   ;  3  abajo-derecha empinado
0114+  6835 00 02       	.DB   0,   2   ;  4  abajo
0115+  6837 FF 02       	.DB 255,   2   ;  5  abajo-izquierda empinado
0116+  6839 FE 02       	.DB 254,   2   ;  6  diagonal DL
0117+  683B FE 01       	.DB 254,   1   ;  7  izquierda-abajo suave
0118+  683D FE 00       	.DB 254,   0   ;  8  izquierda
0119+  683F FE FF       	.DB 254, 255   ;  9  izquierda-arriba suave
0120+  6841 FE FE       	.DB 254, 254   ; 10  diagonal UL
0121+  6843 FF FE       	.DB 255, 254   ; 11  arriba-izquierda empinado
0122+  6845 00 FE       	.DB   0, 254   ; 12  arriba
0123+  6847 01 FE       	.DB   1, 254   ; 13  arriba-derecha empinado
