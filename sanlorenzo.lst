0216+  68C6 DD 77 04    	LD   (IX+4), A           ; edad = 0
0217+  68C9 DD 36 00 52 	LD   (IX+0), Yc          ; Y = centro
0218+  68CD DD 36 01 7C 	LD   (IX+1), Xc          ; X = centro
0219+  68D1 E5          	PUSH HL                  ; salvar puntero sprite buffer
0220+  68D2 C5          	PUSH BC                  ; salvar contador loop (B)
0221+  68D3 CD 4D 68    	CALL RAND                ; A = byte aleatorio
