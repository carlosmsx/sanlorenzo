0127+  684D             ; --- Generador pseudo-aleatorio: Galois LFSR de 8 bits, período 255 ---
0128+  684D             ; Polinomio x^8+x^4+x^3+x^2+1 → feedback = 1Dh
0129+  684D             ; Entrada/salida: A = nuevo byte aleatorio. Solo modifica A y flags.
0130+  684D             RAND:
0131+  684D 3A 05 81    	LD   A, (RAND_SEED)
0132+  6850 B7          	OR   A                   ; ¿semilla = 0? (estado inválido)
0133+  6851 20 01       	JR   NZ, RAND1
0134+  6853 3C          	INC  A                   ; si es 0, usar 1
0135+  6854             RAND1:
0136+  6854 CB 27       	SLA  A                   ; shift izquierda: bit7 → carry, bit0 = 0
0137+  6856 30 02       	JR   NC, RAND2
0138+  6858 EE 1D       	XOR  1Dh                 ; realimentación cuando bit7 era 1
0139+  685A             RAND2:
0140+  685A 32 05 81    	LD   (RAND_SEED), A
0141+  685D C9          	RET
0142+  685E             
0143+  685E             ; --- INIT_STARS: carga patrones en VRAM y copia datos iniciales a RAM ---
0144+  685E             ; Llama una vez desde INSTALL antes de EI.
0145+  685E             INIT_STARS:
0146+  685E 21 A9 67    	LD   HL, SPRTBL          ; 4 patrones × 8 bytes = 32 bytes
0147+  6861 11 00 38    	LD   DE, 03800h          ; tabla patrones sprites en VRAM
0148+  6864 01 20 00    	LD   BC, 32
0149+  6867 CD 5C 00    	CALL LDIRVM
