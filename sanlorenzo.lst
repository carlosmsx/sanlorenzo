0223+  68D8 07          	RLCA                     ; × 2 (cada entrada de DIR_TABLE son 2 bytes)
0224+  68D9 5F          	LD   E, A
0225+  68DA 16 00       	LD   D, 0
0226+  68DC 21 2D 68    	LD   HL, DIR_TABLE
