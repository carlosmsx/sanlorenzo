0832   5117             
0833   5117             ; ============================================================
0834   5117             ; DATOS DE NOTA  (formato: .DB duracion, envolvente, nota)
0835   5117             ;
0836   5117             ; DURACIONES con P_EVOL=4, DELAY=1 a ~60Hz (NTSC) → 120 BPM:
0837   5117             ;   1  = semicorchea (1/16)  ~125ms
0838   5117             ;   2  = corchea     (1/8)   ~250ms
0839   5117             ;   3  = corchea con puntillo(3/16) ~375ms
0840   5117             ;   6  = negra       (1/4)   ~500ms   ← pulso de la marcha
0841   5117             ;   9  = negra con puntillo  (3/8)   ~750ms
0842   5117             ;  12  = blanca      (1/2)  ~1000ms
0843   5117             ;  18  = blanca con puntillo (3/4)  ~1500ms
0844   5117             ;  24  = redonda     (1)    ~2000ms
0845   5117             ; (A 50Hz PAL el tempo sube un 20% → ajustar DELAY o P_EVOL)
0846   5117             ;
0847   5117             ; INDICES DE ENVOLVENTE:
0848   5117             ;   0=EVOL0(decay)  1=EVOL1(vibrato)  2=EVOL2(sostenido)
0849   5117             ;   3=EVOL3(pleno)  4=EVOL4(atk lento) 5=EVOL5(atk muy lento)
0850   5117             ;   6=EVOL6(hw env) 7=EVOL_SIL(silencio)
0851   5117             ;
0852   5117             ; CODIGOS DE NOTA  →  (octava_darkside << 4) | posicion
0853   5117             ;   posicion: C=1 C#=2 D=3 D#=4 E=5 F=6 F#=7 G=8 G#=9 A=10 A#=11 B=12
0854   5117             ;   silencio: 0
0855   5117             ;   Constantes de notas.asm:  A2=0x2A  D2=0x23  F2S=0x27  etc.
0856   5117             ;
0857   5117             ; MAPEO OCTAVAS BASIC → DARKSIDE:
0858   5117             ;   BASIC o1 → darkside 0 (transponer +1 octava)
0859   5117             ;   BASIC o2 → darkside 0
0860   5117             ;   BASIC o3 → darkside 1
0861   5117             ;   BASIC o4 → darkside 2   ← melodia principal
0862   5117             ;   BASIC o5 → darkside 3
0863   5117             ;
0864   5117             ; ORDEN DE SECCIONES (igual al GOSUB del BASIC):
0865   5117             ;   1. Intro/Melodia     (lineas BASIC 1010-2035)
0866   5117             ;   2. Desarrollo        (lineas BASIC 2040-3260)
0867   5117             ;   3. Puente            (lineas BASIC 3310-3415)
0868   5117             ;   4. Estribillo 1      (lineas BASIC 3420-4035)
0869   5117             ;   5. Coda              (lineas BASIC 4040-4960)
0870   5117             ;   6. Estribillo 2      (lineas BASIC 3420-4035 repetido)
0871   5117             ;
0872   5117             ; CHECK reinicia la cancion cuando STAT_A llega a CANALB.
0873   5117             ; CANALB y CANALC deben tener la misma duracion total que CANALA.
0874   5117             ; ============================================================
0875   5117             
0876   5117             CANALA:
0877   5117             #include "canal_a_data.asm"
