0202+  68B4             ; --- UPDATE_STARS: mueve estrellas y actualiza sprites en VRAM cada frame ---
0203+  68B4             ; Llamar desde el handler de interrupción cuando STARS_ON != 0.
0204+  68B4             UPDATE_STARS:
0205+  68B4 DD 21 50 80 	LD   IX, STAR_TABLE      ; IX apunta a la primera estrella
0206+  68B8 21 B4 80    	LD   HL, SPR_BUF         ; HL apunta al buffer de atributos
0207+  68BB 06 14       	LD   B, NUM_STARS        ; 20 estrellas
0208+  68BD             US_LOOP:
0209+  68BD             	; --- Incrementar edad y verificar reset ---
0210+  68BD DD 7E 04    	LD   A, (IX+4)
