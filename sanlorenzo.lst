0189+  68A3 C8          	RET  Z                   ; ya en mínimo (0 = cada tick)
0190+  68A4 3D          	DEC  A
0191+  68A5 32 08 81    	LD   (STAR_DELAY),A
0192+  68A8 C9          	RET
0193+  68A9             
0194+  68A9             STAR_SLOWER:
0195+  68A9 3A 08 81    	LD   A,(STAR_DELAY)
