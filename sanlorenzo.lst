0012+  6785             RAND_SEED    .EQU  08105h   ; semilla del generador pseudo-aleatorio (1 byte)
0013+  6785             STAR_PAT_TMP .EQU  08106h   ; variable temporal para patrón dentro del loop
0014+  6785             STARS_ON     .EQU  08107h   ; flag: 1=estrellas activas, 0=desactivadas
0015+  6785             STAR_DELAY   .EQU  08108h   ; ticks de espera entre actualizaciones (0=cada tick)
