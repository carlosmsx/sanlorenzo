0228+  68E0 7E          	LD   A, (HL)
0229+  68E1 DD 77 02    	LD   (IX+2), A           ; DX aleatorio
0230+  68E4 23          	INC  HL
0231+  68E5 7E          	LD   A, (HL)
0232+  68E6 DD 77 03    	LD   (IX+3), A           ; DY aleatorio
0233+  68E9 C1          	POP  BC
0234+  68EA E1          	POP  HL                  ; restaurar puntero sprite buffer
0235+  68EB 18 15       	JR   US_WRITE
0236+  68ED             US_MOVE:
0237+  68ED DD 77 04    	LD   (IX+4), A           ; guardar edad incrementada
0238+  68F0             	; Y += DY
0239+  68F0 DD 7E 00    	LD   A, (IX+0)
0240+  68F3 DD 86 03    	ADD  A, (IX+3)
0241+  68F6 DD 77 00    	LD   (IX+0), A
0242+  68F9             	; X += DX
0243+  68F9 DD 7E 01    	LD   A, (IX+1)
0244+  68FC DD 86 02    	ADD  A, (IX+2)
0245+  68FF DD 77 01    	LD   (IX+1), A
0246+  6902             US_WRITE:
0247+  6902             	; Patrón: edad >> 3  (0..7 → 0, 8..15 → 1, 16..23 → 2, 24+ → 3)
0248+  6902 DD 7E 04    	LD   A, (IX+4)
0249+  6905 CB 3F       	SRL  A
0250+  6907 CB 3F       	SRL  A
0251+  6909 CB 3F       	SRL  A
0252+  690B FE 04       	CP   4
